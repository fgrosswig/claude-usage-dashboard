# Whitelist: standardmäßig nichts versionieren — nur unten explizit freigegebene Pfade.
# (Kein „Blacklist“-Sammelsurium; lokale Artefakte landen nicht im Index, solange sie nicht whitelisted sind.)

# Alles ignorieren …
*

# … Verzeichnisse wieder sichtbar (sonst keine Rekursion in Unterordner)
!**/

# Repo-Wurzel
!/.gitignore
!/README.md
!/README.en.md
!/server.js
!/start.js
!/anthropic-proxy.js
!/claude-usage-dashboard.js
!/token_forensics.js

!/public/
!/public/**/*

!/scripts/
!/scripts/**/*

!/tpl/
!/tpl/**/*

!/images/
!/images/**/*

# Lokale Secrets / Session-Token — explizit nie committen (Absicherung gegen spätere breitere !-Regeln)
/.github_session_token
/.env
/.env.*
