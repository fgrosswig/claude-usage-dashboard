# Minimales Base: reines Node — kein SCHUFA-OCR/PDF-Stack, kein apk, solange keine Git-URL-Deps / native Libs nötig sind.
# FROM node:20-alpine: Pull beim **base.yml**-Build auf Docker-Agent .220 (Registry/Mirror dort — nicht poc-Pfad im Dockerfile).
FROM node:20-alpine
LABEL maintainer="falk@grosswig.de" version="3"

WORKDIR /app

# NPM Production-Dependencies nur hier — App-Dockerfile kopiert kein node_modules.
# Änderung an package.json / package-lock.json: Woodpecker base.yml baut harbor.../claude/base neu
# (oder auf .220 manuell). Bei Bedarf version.json (base_image) hochziehen + ARG BASE_TAG in Dockerfile.
COPY package.json ./
RUN npm install --omit=dev --no-audit --no-fund
