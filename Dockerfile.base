FROM node:22-alpine
LABEL maintainer="falk@grosswig.de" version="1"

WORKDIR /app

# NPM-Produktionsabhängigkeiten nur hier — App-Dockerfile kopiert kein node_modules.
# Änderung an package.json / package-lock.json: Woodpecker base.yml baut harbor.../claude/base neu (Docker-Agent .220).
COPY package.json package-lock.json ./
RUN npm ci --omit=dev --no-audit --no-fund
