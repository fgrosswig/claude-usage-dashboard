# Nur Harbor (Proxy **poc**). Minimales Base: reines Node — kein SCHUFA-OCR/PDF-Stack, kein apk,
# solange das Dashboard keine nativen Tools oder Git-URL-Dependencies braucht.
FROM harbor.grosswig-it.de/poc/library/node:20-alpine
LABEL maintainer="falk@grosswig.de" version="3"

WORKDIR /app

# NPM Production-Dependencies nur hier — App-Dockerfile kopiert kein node_modules.
# Änderung an package.json / package-lock.json: Woodpecker base.yml baut harbor.../claude/base neu
# (oder auf .220 manuell). Bei Bedarf version.json (base_image) hochziehen + ARG BASE_TAG in Dockerfile.
COPY package.json ./
RUN npm install --omit=dev --no-audit --no-fund
